{
  "name": "robloxstudio-mcp",
  "version": "2.3.0",
  "description": "MCP Server for Roblox Studio Integration - Access Studio data, scripts, and objects through AI tools",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "robloxstudio-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "studio-plugin/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:plugin": "npm --prefix studio-plugin run build && node scripts/build-plugin.mjs",
    "build:all": "npm run build && npm run build:plugin",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --streamable-http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --streamable-http",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build:all"
  },
  "keywords": [
    "mcp",
    "roblox",
    "studio",
    "ai",
    "model-context-protocol",
    "game-development"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boshyxd/robloxstudio-mcp.git"
  },
  "homepage": "https://github.com/boshyxd/robloxstudio-mcp#readme",
  "bugs": {
    "url": "https://github.com/boshyxd/robloxstudio-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.33",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.38.0",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch": "10.2.1"
  }
}
